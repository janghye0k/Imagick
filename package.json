{
  "name": "imagick",
  "description": "Easily resize, convert, compress, and apply filters to images — all directly in your browser. No installation needed. Handle images magically! ✨",
  "version": "0.0.1",
  "private": true,
  "keywords": [
    "browser image editor",
    "online image editor",
    "free online image editor",
    "image converter",
    "svg converter",
    "image compress",
    "image resize",
    "image crop",
    "image transformer",
    "css sprite generator",
    "imagick"
  ],
  "author": {
    "name": "JangHyeok Kim",
    "email": "d0oR.hyeok@gmail.com",
    "url": "https://github.com/janghye0k"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "stylelint": "stylelint \"src/**/*.css\" --allow-empty-input",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix --allow-empty-input"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.45.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^11.15.0",
    "next-themes": "^0.4.6",
    "overlay-kit": "^1.9.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.2",
    "react-router": "^7.13.1",
    "react-simplikit": "^0.0.48",
    "recharts": "2.15.4",
    "shadcn": "^4.0.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
